# --- Postgres (Compose 서비스명: db) ---
POSTGRES_USER=campus_admin
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=campusdrop
DATABASE_URL=postgresql://campus_admin:change-me-strong@db:5432/campusdrop
# 로컬에서 Prisma Studio/npm run db:* 가 원격 RDS에 못 붙을 때: git 무시되는 `.env.local`에만
# DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5432/campusdrop 처럼 로컬 DB URL을 두고 덮어쓰기

# --- Redis (Compose 서비스명: redis) ---
# Docker Compose 안에서만: redis://redis:6379
# Windows에서 npm start만 할 때: Redis를 로컬 6379에 띄운 뒤 예) REDIS_URL=redis://127.0.0.1:6379
#   (Docker Desktop 실행 후: docker run -d --name campusdrop-redis -p 6379:6379 redis:7-alpine)
REDIS_URL=redis://redis:6379

# --- Node API 호스트 포트(Compose published port) ---
SERVER_PUBLISH_PORT=3000

# --- Python 매칭(Compose 서비스명: matching) ---
MATCHING_SERVICE_URL=http://matching:8000

# --- 이메일 ---
# 로컬·EC2 모두 동일하게: SMTP(SES SMTP 자격 증명) 또는 SES API 중 하나만 쓰면 됩니다.
#
# A) SES SMTP (권장: IAM·키 없이 SMTP 사용자만 EC2에 넣기 쉬움)
EMAIL_TRANSPORT=smtp
SMTP_HOST=email-smtp.ap-northeast-2.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME_SES_SMTP_USERNAME
SMTP_PASS=CHANGE_ME_SES_SMTP_PASSWORD
SMTP_FROM="Campus Drop <sju@campus-drop.com>"
# FROM_EMAIL 은 SMTP_FROM 과 동일 역할(호환용, 선택)
#
# B) SES HTTP API (EMAIL_TRANSPORT 생략 또는 ses)
# AWS_REGION=ap-northeast-2
# SES_FROM_EMAIL=noreply@campus-drop.com
# 발신 표시 이름(비우면 코드 기본값 Campus Drop → "Campus Drop <SES_FROM_EMAIL>")
# SES_FROM_DISPLAY_NAME=Campus Drop
# 인증 메일 HTML 상단 로고 URL. 비우면 PUBLIC_API_URL + /assets/logo.png (아래 정적 경로) 사용
# EMAIL_LOGO_URL=https://campus-drop.com/some-path/logo.png
# SES_CONFIGURATION_SET=my-config-set
# IAM Role 권장. 로컬만 키 사용 시:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# 개발·SES 대기 시에만: 비우지 않으면 항상 이 코드만 유효하고 인증 메일을 보내지 않음. 운영에서는 반드시 비울 것.
# AUTH_FIXED_VERIFICATION_CODE=1234

# 신규 가입: verify-code 직후 발급되는 registration JWT 서명(16자 이상 권장). 미설정 시 ADMIN_JWT_SECRET 또는 ADMIN_PASSWORD로 파생
# AUTH_REGISTRATION_JWT_SECRET=
# 가입 토큰 만료(초). 기본 3600(1시간)
# AUTH_REGISTRATION_JWT_EXPIRES_SEC=3600

# --- 앱 ---
PORT=3000
# HOST=0.0.0.0
# PUBLIC_API_URL=https://api.campus-drop.com
# 추가 CORS(쉼표 구분). https://campus-drop.com·www 는 코드에 기본 포함
# CORS_ORIGINS=http://localhost:5173
# 관리자 프론트 전용 CORS(쉼표 구분). 비우면 CORS_ORIGINS·기본 도메인만 적용
# ADMIN_CORS_ORIGINS=http://localhost:5174,https://admin.campus-drop.com

# --- 관리자 API ---
# `npm run db:seed` 시 DB `admins` 테이블에 upsert(로그인은 항상 DB에서 검증)
# ADMIN_EMAIL=admin@sju.ac.kr
# ADMIN_PASSWORD=change-me-admin-only
# `admins.password_hash`만 bcrypt로 고치려면(Studio에 평문 넣은 경우): npm run admin:upsert
# JWT 서명(16자 이상 권장). 미설정 시 ADMIN_PASSWORD로 결정적 파생(시드용 비번과 같이 쓰는 경우)
# ADMIN_JWT_SECRET=
# 토큰 만료(초). 기본 28800(8시간)
# ADMIN_JWT_EXPIRES_SEC=28800

# 학교 증빙 이미지 업로드(바이트). 기본 5242880(5MB)
# SCHOOL_PROOF_MAX_BYTES=5242880

# Prisma: prisma/schema.prisma 의 DATABASE_URL (위 DATABASE_URL과 비밀번호·호스트 일치)

# --- 공개 분석 API (/api/analytics/*) ---
# Nginx 등 리버스 프록시 뒤에서 IP·레이트리밋을 맞추려면 1
# TRUST_PROXY=1
# JSON 본문 상한(숫자 바이트 또는 예: 512kb, 1mb). 기본 512KiB
# ANALYTICS_JSON_BODY_MAX_BYTES=524288
# ANALYTICS_MAX_EVENTS_PER_REQUEST=200
# ANALYTICS_MAX_INTERACTIONS_PER_REQUEST=100
# ANALYTICS_MAX_BATCH_ITEMS=50
# ANALYTICS_RATE_WINDOW_SEC=60
# ANALYTICS_EVENTS_PER_IP_PER_WINDOW=200
# ANALYTICS_EVENTS_PER_SESSION_PER_WINDOW=120
# ANALYTICS_HEARTBEAT_PER_IP_PER_WINDOW=300
# ANALYTICS_HEARTBEAT_PER_SESSION_PER_WINDOW=200
# ANALYTICS_INTERACTION_PER_IP_PER_WINDOW=40
# ANALYTICS_INTERACTION_PER_SESSION_PER_WINDOW=30
# ANALYTICS_INTERACTIONS_PER_SESSION_PER_DAY=8000
# ANALYTICS_BATCH_PER_IP_PER_WINDOW=30
# ANALYTICS_BATCH_PER_SESSION_PER_WINDOW=20

# --- 카카오 로그인 (POST /api/auth/kakao) ---
# Kakao Developers REST API 키. 콘솔에서 카카오 로그인·Redirect URI·(선택) Client Secret 활성화
# KAKAO_REST_API_KEY=
# Client Secret 사용 시(콘솔 활성화와 일치)
# KAKAO_CLIENT_SECRET=
# 나에게 보내기 메모 내 링크(web/mobile). 미설정 시 PUBLIC_API_URL·APP_WEB_URL·campus-drop.com 순으로 사용
# KAKAO_MEMO_LINK_URL=https://campus-drop.com

# 카카오 매칭 피드백 리마인드(매일 18:00 KST). 쉼표로 구분한 Identity UUID — 리프레시 토큰이 DB에 있는 계정만 전송됨
# (프론트 카카오 로그인 동의항목에 `talk_message`(나에게 보내기) 포함 시 로그인 응답에 refresh_token이 올 수 있음)
# 메시지: 기본은 DB `meeting_time`·`meeting_place`(+ 아래 기본값)에서 `오늘 {시간} [{장소짧음}] 만남 …` 형태로 생성. 전역 고정 문자열만 쓰려면 설정
# KAKAO_CRON_REMINDER_TEXT=
# KAKAO_CRON_NOTIFY_IDENTITY_UUIDS=
# 스케줄러 등록 자체를 끄려면 true
# KAKAO_MATCHING_REMINDER_CRON_DISABLED=false

# --- 소개팅 QR 채팅 (MEET_CHAT_QR_SECRET 미설정 시 /api/meet-chat·QR 발급 API 비활성) ---
# openssl rand -base64 48 등으로 충분히 긴 무작위 문자열 권장
# MEET_CHAT_QR_SECRET=

# POST /api/auth/kakao 시 만남 필드 미전달·크론용 폴백(비어 있으면 코드 내장 예시: 금요일 오후 6시 / 세종대 후문 커피니)
# DEFAULT_MEETING_TIME=이번 주 금요일 오후 6시
# DEFAULT_MEETING_PLACE=세종대 후문 커피니
# 카카오 등 추가 키는 기존 campusdrop_server 운영 설정을 이 파일에 그대로 합치면 됩니다.

# --- Solapi 카카오 친구톡 테스트 (POST /api/test-message) ---
# SOLAPI_API_KEY=
# SOLAPI_API_SECRET=
# SENDER_NUMBER=01012345678
# KAKAO_PF_ID=카카오톡 채널 검색용 아이디(채널·Solapi 콘솔 값)
# 레거시 친구톡 RSVP ?t= 링크 검증용 서명(openssl rand -hex 32 등 16자 이상 권장)
# FRIEND_TALK_RSVP_SECRET=
# 설문/프로필 전화번호 DB 저장용 대칭키(32바이트). base64 또는 hex 문자열
# 예) openssl rand -base64 32
# PHONE_ENCRYPTION_KEY=
# 매칭 전날 6번 친구톡 자동 발송 크론(매일 18:00 KST). 끄려면 true
# FRIEND_TALK_DAY_EVE_CRON_DISABLED=false
# phone_encrypted 없는 Identity 정리 크론(매일 00:00 KST). 끄려면 true
# IDENTITY_WITHOUT_PHONE_PURGE_CRON_DISABLED=false
#
# 친구톡 이미지(CTI): 로컬 경로 또는 공개 https 이미지 URL. Solapi 규격 약 500KB — 카카오 업로드 시 링크 필수
# FRIEND_TALK_IMG_LINK=https://campus-drop.com
# 파일명 예: matching_remind / matching_failed / matching_success (확장자는 실제 파일에 맞게)
# Docker: campusdrop_server/assets/friend-talk/ → 컨테이너 /app/assets/friend-talk/
# FRIEND_TALK_IMG_DAY_EVE=/app/assets/friend-talk/matching_remind.jpg
# FRIEND_TALK_IMG_MATCH_FAIL=/app/assets/friend-talk/matching_failed.jpg
# FRIEND_TALK_IMG_MATCH_SUCCESS=/app/assets/friend-talk/matching_success.jpg
