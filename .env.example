# --- Postgres (Compose 서비스명: db) ---
POSTGRES_USER=campus_admin
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=campusdrop
DATABASE_URL=postgresql://campus_admin:change-me-strong@db:5432/campusdrop

# --- Redis (Compose 서비스명: redis) ---
REDIS_URL=redis://redis:6379

# --- Node API 호스트 포트(Compose published port) ---
SERVER_PUBLISH_PORT=3000

# --- Python 매칭(Compose 서비스명: matching) ---
MATCHING_SERVICE_URL=http://matching:8000

# --- 이메일 ---
# 로컬·EC2 모두 동일하게: SMTP(SES SMTP 자격 증명) 또는 SES API 중 하나만 쓰면 됩니다.
#
# A) SES SMTP (권장: IAM·키 없이 SMTP 사용자만 EC2에 넣기 쉬움)
EMAIL_TRANSPORT=smtp
SMTP_HOST=email-smtp.ap-northeast-2.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME_SES_SMTP_USERNAME
SMTP_PASS=CHANGE_ME_SES_SMTP_PASSWORD
SMTP_FROM="Campus Drop <sju@campus-drop.com>"
# FROM_EMAIL 은 SMTP_FROM 과 동일 역할(호환용, 선택)
#
# B) SES HTTP API (EMAIL_TRANSPORT 생략 또는 ses)
# AWS_REGION=ap-northeast-2
# SES_FROM_EMAIL=noreply@campus-drop.com
# SES_CONFIGURATION_SET=my-config-set
# IAM Role 권장. 로컬만 키 사용 시:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# 개발·SES 대기 시에만: 비우지 않으면 항상 이 코드만 유효하고 인증 메일을 보내지 않음. 운영에서는 반드시 비울 것.
# AUTH_FIXED_VERIFICATION_CODE=1234

# --- 앱 ---
PORT=3000
# HOST=0.0.0.0
# PUBLIC_API_URL=https://api.campus-drop.com
# 추가 CORS(쉼표 구분). https://campus-drop.com·www 는 코드에 기본 포함
# CORS_ORIGINS=http://localhost:5173
# 관리자 프론트 전용 CORS(쉼표 구분). 비우면 CORS_ORIGINS·기본 도메인만 적용
# ADMIN_CORS_ORIGINS=http://localhost:5174,https://admin.campus-drop.com

# --- 관리자 API ---
# `npm run db:seed` 시 DB `admins` 테이블에 upsert(로그인은 항상 DB에서 검증)
# ADMIN_EMAIL=admin@sju.ac.kr
# ADMIN_PASSWORD=change-me-admin-only
# `admins.password_hash`만 bcrypt로 고치려면(Studio에 평문 넣은 경우): npm run admin:upsert
# JWT 서명(16자 이상 권장). 미설정 시 ADMIN_PASSWORD로 결정적 파생(시드용 비번과 같이 쓰는 경우)
# ADMIN_JWT_SECRET=
# 토큰 만료(초). 기본 28800(8시간)
# ADMIN_JWT_EXPIRES_SEC=28800

# Prisma: prisma/schema.prisma 의 DATABASE_URL (위 DATABASE_URL과 비밀번호·호스트 일치)

# 카카오 등 추가 키는 기존 campusdrop_server 운영 설정을 이 파일에 그대로 합치면 됩니다.
