// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 계정·로그인 식별. 인증 완료 시 정규화된 `@sju.ac.kr` 주소를 `email`에 보관(수사·고객 특정).
model Identity {
  id        String   @id @default(uuid()) @db.Uuid
  /// `normalizeEmail` 적용 후 문자열. 구 가입자는 재인증 전 null일 수 있음.
  email     String?  @unique
  /// 정규화된 이메일 문자열에 대한 bcrypt 해시(솔트 포함). 로그인 시 `bcrypt.compare`로만 대조합니다.
  emailHash String
  kakaoId   String?  @unique
  /// 카카오 OAuth 리프레시 토큰(있을 때만). `talk_message` 등 동의 시 로그인 응답에 포함되며, 주기 알림 스케줄러에서 갱신·나에게 보내기에 사용합니다.
  kakaoRefreshToken String? @map("kakao_refresh_token")
  /// 카카오 챗봇 연동용 4자리 PIN. 다른 `Identity`와 중복 불가. 재요청 시 동일 값 유지, 연동 성공 시 null.
  kakaoLinkPin String? @unique @map("kakao_link_pin")
  /// 관리자 차단 시각. null이면 정상 이용 가능.
  blockedAt DateTime? @map("blocked_at")
  /// 학생증·재학증명 등 이미지 제출을 관리자가 승인한 시각. null이면 아직 이미지 인증 미완료.
  schoolProofVerifiedAt DateTime? @map("school_proof_verified_at")
  /// 익명(이미지 전용) 온보딩으로 생성된 계정만 설정. `matchPolicy` 매칭 주 종료 시각까지 `x-user-uuid`로 설문·매칭 API 접근 허용. 이메일 연동 시 null로 돌림.
  imageUuidAccessUntil DateTime? @map("image_uuid_access_until")
  /// 설문 `participantMeta.profile`에서 동기화(선택). 조회·운영 편의용.
  studentId String? @map("student_id")
  birthYear String? @map("birth_year")
  department String?
  /// 가입·이메일 연결·온보딩 시 수집. 구 가입자 마이그레이션 후 기본값 false일 수 있음.
  privacyPolicyAgreed Boolean @default(false) @map("privacy_policy_agreed")
  /// 만남 일정 라벨(자유 문자열). 알림에서는 `오전/오후 n시` 조각 우선 추출.
  meetingTime String? @map("meeting_time")
  /// 만남 장소(자유 문자열). 알림에서는 마지막 어절을 대괄호 안 표기에 사용합니다.
  meetingPlace String? @map("meeting_place")
  createdAt DateTime @default(now())
  trait     Trait?
  weeklySurveySubmissions WeeklySurveySubmission[]

  schoolProofSubmissions SchoolProofSubmission[]

  /// 이 유저이 `user_a_id`로 참여한 매칭 행(과거·현재 쌍). 특정 유저의 “매칭된 상대 목록”은 `matchesAsUserA` ∪ `matchesAsUserB` 로 `matchings`에서 조회.
  matchesAsUserA Matching[] @relation("MatchPairUserA")
  /// 이 유저이 `user_b_id`로 참여한 매칭 행.
  matchesAsUserB Matching[] @relation("MatchPairUserB")

  meetingChatMessages MeetingChatMessage[] @relation("MeetingChatSender")

  @@index([emailHash])
  @@map("identities")
}

/// 성향·설문 등 비식별 속성(1:1 `Identity`). PK = `Identity.id`와 동일(FK).
model Trait {
  id                String    @id @db.Uuid
  identity          Identity  @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  /// 설문 `gender`와 동기화. `male` | `female` (이성 매칭용).
  gender            String?
  surveyData        Json?
  /// 사용자가 설문을 실제 제출한 시각. 관리자 보정 등 일반 Trait 업데이트와 분리해 주간 신청 여부를 판단합니다.
  surveySubmittedAt DateTime? @map("survey_submitted_at")
  updatedAt         DateTime  @updatedAt

  @@index([surveySubmittedAt])
  @@map("traits")
}

/// 주차별 설문 제출 스냅샷. 한 유저가 같은 매칭 주에 다시 제출하면 최신 제출로 덮어씁니다.
model WeeklySurveySubmission {
  id                String   @id @default(uuid()) @db.Uuid
  identityId        String   @map("identity_id") @db.Uuid
  identity          Identity @relation(fields: [identityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  targetPeriodStart DateTime @map("target_period_start")
  targetPeriodEnd   DateTime @map("target_period_end")
  gender            String?
  surveyData        Json     @map("survey_data")
  submittedAt       DateTime @map("submitted_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([identityId, targetPeriodStart])
  @@index([targetPeriodStart, submittedAt])
  @@map("weekly_survey_submissions")
}

// --- 감사 로그 / 관리자 접근 (설계 주석) ---
// 비상(break-glass) 시에만 관리자가 PII에 근접할 수 있도록 다음을 권장합니다(코드가 아닌 운영·보안 정책으로 강제):
// 1) 관리자 API는 본 앱과 분리된 내부망 + mTLS + 단기 자격 증명만 허용.
// 2) 역할: `break_glass_auditor` 등 최소 역할 + 2인 승인(M-of-N) + 시간창(예: 4시간) 제한.
// 3) 모든 특권 조회/보내기는 반드시 `AccessLog`에 남기고, SOC에서 `actorType === "admin"` 알림.
// 4) DB 직접 접속은 금지하거나 별도 Vault 감사와 이중화.
// 5) 구현 시: 관리 라우트에서 `writeAccessLog({ actorType: "admin", ... })` 호출을 강제하는 미들웨어를 둘 것.
model AccessLog {
  id         String   @id @default(uuid()) @db.Uuid
  /// 예: "user_session" | "system" | "admin" | "job"
  actorType  String
  /// 불투명 actor 식별자(관리자 서브 등). 없으면 null.
  actorId    String?
  /// 예: "AUTH_SESSION_VALIDATE" | "TRAIT_UPDATE" | "ADMIN_EXPORT"
  action     String
  /// 예: "Trait:<uuid>" — 원문 이메일·카카오 ID는 기록하지 말 것.
  resource   String?
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorType, action])
  @@map("access_logs")
}

/// 관리자 콘솔 전용 계정(일반 `Identity`와 분리). `email`은 로그인용 정규화 문자열(소문자 등).
model Admin {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}

/// 매칭 이력: 한 행 = 한 쌍(user A, user B). 주간 배치·관리자 강제 매칭 등 동일 테이블에 적재.
/// 특정 `Identity.id`에 대해 `WHERE user_a_id = :id OR user_b_id = :id` 가 그 유저의 지금까지 매칭 상대 이력.
model Matching {
  id        String   @id @default(uuid()) @db.Uuid
  userAId   String   @map("user_a_id") @db.Uuid
  userBId   String   @map("user_b_id") @db.Uuid
  score     Float
  matchedAt DateTime @default(now()) @map("matched_at")
  /// 2026-04-13 KST 앵커부터 7일 단위 주간 버킷 시작. 같은 주·같은 유저가 다시 매칭되면 기존 행을 지우고 다시 넣음.
  periodStart DateTime? @map("period_start")
  /// 배치 시점 Python `compute_match`의 `match_report` 스냅샷(요약·축별 정렬 등). 강제 매칭 등 없으면 null.
  matchReport Json? @map("match_report")
  /// 소개팅 약속 시각(KST 벽시계 기준으로 저장한 순간의 UTC 인스턴스). QR 채팅 시간대 계산에 사용.
  meetingStartsAt DateTime? @map("meeting_starts_at")
  /// 채팅방 제목 등에 쓰는 장소명(예: 카페 이름).
  meetingVenueName String? @map("meeting_venue_name")

  userA Identity @relation("MatchPairUserA", fields: [userAId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userB Identity @relation("MatchPairUserB", fields: [userBId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  chatMessages MeetingChatMessage[]

  @@index([matchedAt])
  @@index([periodStart])
  @@index([userAId])
  @@index([userBId])
  @@index([meetingStartsAt])
  @@map("matchings")
}

/// 소개팅 매칭 단위 QR 채팅 메시지. 행은 유지되며 관리자는 항상 조회 가능.
model MeetingChatMessage {
  id         String   @id @default(uuid()) @db.Uuid
  matchingId String   @map("matching_id") @db.Uuid
  matching   Matching @relation(fields: [matchingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  senderId   String   @map("sender_id") @db.Uuid
  sender     Identity @relation("MeetingChatSender", fields: [senderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  body       String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([matchingId, createdAt])
  @@map("meeting_chat_messages")
}

/// 학교 소속 증빙 이미지 제출 1건. 이메일 인증과 별도로 관리자가 `approved` 처리하면 `Identity.schoolProofVerifiedAt`이 설정됩니다.
model SchoolProofSubmission {
  id         String   @id @default(uuid()) @db.Uuid
  identityId String   @map("identity_id") @db.Uuid
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  /// 서버 루트 기준 상대 경로(예: uploads/school-proof/<uuid>.jpg). 외부 공개 URL이 아닙니다.
  storedPath String   @map("stored_path")
  mimeType   String   @map("mime_type")
  fileSize   Int      @map("file_size")
  /// pending | approved | rejected
  status     String   @default("pending")
  reviewedAt DateTime? @map("reviewed_at")
  reviewerAdminId String? @map("reviewer_admin_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@index([identityId, status])
  @@index([status, createdAt])
  @@map("school_proof_submissions")
}

/// 공개 웹앱 행동 분석 — 의미 있는 이벤트(퍼널·화면 등). 행 단위 append-only.
model AnalyticsEvent {
  id             String    @id @default(uuid()) @db.Uuid
  sessionId      String    @map("session_id") @db.Uuid
  userUuid       String?   @map("user_uuid") @db.Uuid
  app            String
  release        String?
  clientTs       DateTime? @map("client_ts")
  name           String
  eventTs        DateTime  @map("event_ts")
  props          Json?
  /// 선택. 이후 idempotency·중복 제거용으로 클라이언트가 보낼 수 있음(현재는 저장만).
  clientEventId  String?   @map("client_event_id") @db.Uuid
  receivedAt     DateTime  @default(now()) @map("received_at")

  @@index([sessionId, receivedAt])
  @@index([app, eventTs])
  @@index([receivedAt])
  @@map("analytics_events")
}

/// 세션당 최신 하트비트·이탈(10분 무활동) 집계용 narrow 행. UPSERT.
model AnalyticsSessionHeartbeat {
  sessionId                String    @id @map("session_id") @db.Uuid
  userUuid                 String?   @map("user_uuid") @db.Uuid
  lastMeaningfulActivityAt DateTime  @map("last_meaningful_activity_at")
  visibility               String?
  context                  Json?
  clientTs                 DateTime? @map("client_ts")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  @@index([lastMeaningfulActivityAt])
  @@map("analytics_session_heartbeats")
}

/// dead click·rage tap 등 고밀도 상호작용. append-only.
model AnalyticsInteraction {
  id              String   @id @default(uuid()) @db.Uuid
  sessionId       String   @map("session_id") @db.Uuid
  userUuid        String?  @map("user_uuid") @db.Uuid
  type            String
  ts              DateTime
  xNorm           Float    @map("x_norm")
  yNorm           Float    @map("y_norm")
  nearestRegion   String   @map("nearest_region")
  view            String
  receivedAt      DateTime @default(now()) @map("received_at")

  @@index([sessionId, ts])
  @@index([type, receivedAt])
  @@map("analytics_interactions")
}

/// `x-user-uuid`가 온 요청에서 session_id ↔ Identity.id 연결(선택).
model AnalyticsSessionUserLink {
  sessionId String   @id @map("session_id") @db.Uuid
  userUuid  String   @map("user_uuid") @db.Uuid
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userUuid])
  @@map("analytics_session_user_links")
}

/// 랜딩 화면 더블탭 좋아요 합계. 행 키는 고정(`default`) 한 줄만 사용합니다.
model LandingLikeCounter {
  key       String   @id @map("key")
  likeCount Int      @default(0) @map("like_count")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("landing_like_counters")
}
