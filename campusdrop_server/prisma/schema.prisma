// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 계정·로그인 식별. 인증 완료 시 정규화된 `@sju.ac.kr` 주소를 `email`에 보관(수사·고객 특정).
model Identity {
  id        String   @id @default(uuid()) @db.Uuid
  /// 표시용 닉네임. `형용사 + 생물명사` 자동 생성 + DB 유니크로 중복 방지.
  nickname  String?  @unique
  /// `normalizeEmail` 적용 후 문자열. 구 가입자는 재인증 전 null일 수 있음.
  email     String?  @unique
  kakaoId   String?  @unique
  /// 카카오 OAuth 리프레시 토큰(있을 때만). `talk_message` 등 동의 시 로그인 응답에 포함되며, 주기 알림 스케줄러에서 갱신·나에게 보내기에 사용합니다.
  kakaoRefreshToken String? @map("kakao_refresh_token")
  /// 카카오 챗봇 연동용 4자리 PIN. 다른 `Identity`와 중복 불가. 재요청 시 동일 값 유지, 연동 성공 시 null.
  kakaoLinkPin String? @unique @map("kakao_link_pin")
  /// 관리자 차단 시각. null이면 정상 이용 가능.
  blockedAt DateTime? @map("blocked_at")
  /// 학생증·재학증명 등 이미지 제출을 관리자가 승인한 시각. null이면 아직 이미지 인증 미완료.
  schoolProofVerifiedAt DateTime? @map("school_proof_verified_at")
  /// 익명(이미지 전용) 온보딩으로 생성된 계정만 설정. `matchPolicy` 매칭 주 종료 시각까지 `x-user-uuid`로 설문·매칭 API 접근 허용. 이메일 연동 시 null로 돌림.
  imageUuidAccessUntil DateTime? @map("image_uuid_access_until")
  /// 설문 `participantMeta.profile`에서 동기화(선택). 조회·운영 편의용.
  studentId String? @map("student_id")
  birthYear String? @map("birth_year")
  department String?
  /// 설문/프로필에서 수집한 휴대폰 번호(01… 11자리)를 AES-GCM으로 암호화한 문자열.
  phoneEncrypted String? @map("phone_encrypted")
  /// 가입·이메일 연결·온보딩 시 수집. 구 가입자 마이그레이션 후 기본값 false일 수 있음.
  privacyPolicyAgreed Boolean @default(false) @map("privacy_policy_agreed")
  /// 만남 일정 라벨(자유 문자열). 알림에서는 `오전/오후 n시` 조각 우선 추출.
  meetingTime String? @map("meeting_time")
  /// 만남 장소(자유 문자열). 알림에서는 마지막 어절을 대괄호 안 표기에 사용합니다.
  meetingPlace String? @map("meeting_place")
  /// 첫 주간 설문 후 친구톡 유입 경로 버튼 응답(한 번만 저장). slug: everytime | instagram | friend | poster
  acquisitionSource String? @map("acquisition_source")
  createdAt DateTime @default(now())
  trait     Trait?
  weeklySurveySubmissions        WeeklySurveySubmission[]
  friendWeeklySurveySubmissions  FriendWeeklySurveySubmission[]

  schoolProofSubmissions SchoolProofSubmission[]

  /// 이 유저이 `user_a_id`로 참여한 매칭 행(과거·현재 쌍). 특정 유저의 “매칭된 상대 목록”은 `matchesAsUserA` ∪ `matchesAsUserB` 로 `matchings`에서 조회.
  matchesAsUserA Matching[] @relation("MatchPairUserA")
  /// 이 유저이 `user_b_id`로 참여한 매칭 행.
  matchesAsUserB Matching[] @relation("MatchPairUserB")

  meetingChatMessages MeetingChatMessage[] @relation("MeetingChatSender")
  meetingFeedbacks    MatchingMeetingFeedback[]

  @@map("identities")
}

/// 성향·설문 등 비식별 속성(1:1 `Identity`). PK = `Identity.id`와 동일(FK).
model Trait {
  id                String    @id @db.Uuid
  identity          Identity  @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  /// 설문 `gender`와 동기화. `male` | `female` (이성 매칭용). 로맨스 설문 제출 시 갱신.
  gender            String?
  /// 로맨스(가치관) 설문 JSON. `POST /api/survey/submit`만 갱신.
  surveyData        Json?
  /// 친구(취미 등) 설문 JSON. `POST /api/survey/friend/submit`만 갱신.
  friendSurveyData  Json?    @map("friend_survey_data")
  /// 로맨스 설문 실제 제출 시각.
  surveySubmittedAt DateTime? @map("survey_submitted_at")
  friendSurveySubmittedAt DateTime? @map("friend_survey_submitted_at")
  updatedAt         DateTime  @updatedAt

  @@index([surveySubmittedAt])
  @@map("traits")
}

/// 로맨스 매칭용 주차별 설문 스냅샷. DB 테이블명 `weekly_survey_submissions`(레거시).
model WeeklySurveySubmission {
  id                String   @id @default(uuid()) @db.Uuid
  identityId        String   @map("identity_id") @db.Uuid
  identity          Identity @relation(fields: [identityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  targetPeriodStart DateTime @map("target_period_start")
  targetPeriodEnd   DateTime @map("target_period_end")
  gender            String?
  surveyData        Json     @map("survey_data")
  submittedAt       DateTime @map("submitted_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([identityId, targetPeriodStart])
  @@index([targetPeriodStart, submittedAt])
  @@map("weekly_survey_submissions")
}

/// 친구 매칭용 주차별 설문 스냅샷.
model FriendWeeklySurveySubmission {
  id                String   @id @default(uuid()) @db.Uuid
  identityId        String   @map("identity_id") @db.Uuid
  identity          Identity @relation(fields: [identityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  targetPeriodStart DateTime @map("target_period_start")
  targetPeriodEnd   DateTime @map("target_period_end")
  gender            String?
  surveyData        Json     @map("survey_data")
  submittedAt       DateTime @map("submitted_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([identityId, targetPeriodStart])
  @@index([targetPeriodStart, submittedAt])
  @@map("friend_weekly_survey_submissions")
}

// --- 감사 로그 / 관리자 접근 (설계 주석) ---
// 비상(break-glass) 시에만 관리자가 PII에 근접할 수 있도록 다음을 권장합니다(코드가 아닌 운영·보안 정책으로 강제):
// 1) 관리자 API는 본 앱과 분리된 내부망 + mTLS + 단기 자격 증명만 허용.
// 2) 역할: `break_glass_auditor` 등 최소 역할 + 2인 승인(M-of-N) + 시간창(예: 4시간) 제한.
// 3) 모든 특권 조회/보내기는 반드시 `AccessLog`에 남기고, SOC에서 `actorType === "admin"` 알림.
// 4) DB 직접 접속은 금지하거나 별도 Vault 감사와 이중화.
// 5) 구현 시: 관리 라우트에서 `writeAccessLog({ actorType: "admin", ... })` 호출을 강제하는 미들웨어를 둘 것.
model AccessLog {
  id         String   @id @default(uuid()) @db.Uuid
  /// 예: "user_session" | "system" | "admin" | "job"
  actorType  String
  /// 불투명 actor 식별자(관리자 서브 등). 없으면 null.
  actorId    String?
  /// 예: "AUTH_SESSION_VALIDATE" | "TRAIT_UPDATE" | "ADMIN_EXPORT"
  action     String
  /// 예: "Trait:<uuid>" — 원문 이메일·카카오 ID는 기록하지 말 것.
  resource   String?
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorType, action])
  @@map("access_logs")
}

/// 관리자 콘솔 전용 계정(일반 `Identity`와 분리). `email`은 로그인용 정규화 문자열(소문자 등).
model Admin {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}

/// 매칭 이력: 한 행 = 한 쌍(user A, user B). 주간 배치·관리자 강제 매칭 등 동일 테이블에 적재.
/// 특정 `Identity.id`에 대해 `WHERE user_a_id = :id OR user_b_id = :id` 가 그 유저의 지금까지 매칭 상대 이력.
model Matching {
  id        String   @id @default(uuid()) @db.Uuid
  userAId   String   @map("user_a_id") @db.Uuid
  userBId   String   @map("user_b_id") @db.Uuid
  /// ROMANCE | FRIEND. 동일 기간에 타입별 매칭을 분리 저장합니다.
  matchType String   @default("ROMANCE") @map("match_type")
  score     Float
  matchedAt DateTime @default(now()) @map("matched_at")
  /// 2026-04-13 KST 앵커부터 7일 단위 주간 버킷 시작. 같은 주·같은 유저가 다시 매칭되면 기존 행을 지우고 다시 넣음.
  periodStart DateTime? @map("period_start")
  /// 배치 시점 Python `compute_match`의 `match_report` 스냅샷(요약·축별 정렬 등). 강제 매칭 등 없으면 null.
  matchReport Json? @map("match_report")
  /// 소개팅 약속 시각(KST 벽시계 기준으로 저장한 순간의 UTC 인스턴스). QR 채팅 시간대 계산에 사용.
  meetingStartsAt DateTime? @map("meeting_starts_at")
  /// 채팅방 제목 등에 쓰는 장소명(예: 카페 이름). 배치 시 `cafe.name` 스냅샷이 들어가며, 카페 이름이 바뀌어도 과거 매칭은 당시 이름을 보존합니다.
  meetingVenueName String? @map("meeting_venue_name")
  /// 배치 시 라운드로빈으로 배정되는 카페 FK. 카페가 삭제되면 NULL로 끊어지고 `meetingVenueName` 스냅샷은 남습니다.
  cafeId String? @map("cafe_id") @db.Uuid

  userA Identity @relation("MatchPairUserA", fields: [userAId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userB Identity @relation("MatchPairUserB", fields: [userBId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cafe  Cafe?    @relation(fields: [cafeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  chatMessages MeetingChatMessage[]
  friendTalkRsvp MatchingFriendTalkRsvp?
  /// 만남 당일 후기 친구톡(3버튼) 발송 시각 — 중복 방지
  feedbackFriendTalkSentAt DateTime? @map("feedback_friend_talk_sent_at")
  meetingFeedbacks MatchingMeetingFeedback[]

  @@index([matchedAt])
  @@index([matchType, periodStart])
  @@index([periodStart])
  @@index([userAId])
  @@index([userBId])
  @@index([meetingStartsAt])
  @@index([cafeId])
  @@map("matchings")
}

/// 매칭 카페 마스터. 관리자 콘솔에서 등록/수정/비활성화. 배치 매칭은 `isActive=true`만 `displayOrder` 순으로 라운드로빈 배정합니다.
model Cafe {
  id             String   @id @default(uuid()) @db.Uuid
  /// 카카오톡·QR 채팅 등 사용자 노출 이름. 트리밍·중복 방지(@unique)로 한 카페는 한 행만.
  name           String   @unique
  /// 네이버 지도 등 외부 링크(선택).
  naverPlaceUrl  String?  @map("naver_place_url")
  /// 운영 메모용 자유 주소 문자열(선택).
  address        String?
  /// false면 배치 매칭에서 제외(카페 자체는 보존). 기존 `Matching.cafeId` 참조는 유지.
  isActive       Boolean  @default(true) @map("is_active")
  /// 라운드로빈 배정 순서. 같은 슬롯에 여러 매칭이 들어갈 때 0부터 우선 배정.
  displayOrder   Int      @default(0) @map("display_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  matchings Matching[]

  @@index([isActive, displayOrder])
  @@map("cafes")
}

/// 7번(월요 일정)·6번(전날) 친구톡 응답·수신번호 보관. 매칭 1행당 최대 1행.
model MatchingFriendTalkRsvp {
  matchingId String @id @map("matching_id") @db.Uuid
  matching   Matching @relation(fields: [matchingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  /// Solapi 발신 대상(01… 11자리). userAId / userBId 순과 동일.
  phoneUserA String @map("phone_user_a")
  phoneUserB String @map("phone_user_b")

  /// 7번(일정 안내) 버튼 응답: YES | NO
  mondayRsvpUserA String? @map("monday_rsvp_user_a")
  mondayRsvpUserB String? @map("monday_rsvp_user_b")
  /// 6번(전날) 버튼 응답
  dayEveRsvpUserA String? @map("day_eve_rsvp_user_a")
  dayEveRsvpUserB String? @map("day_eve_rsvp_user_b")

  /// 7번에서 한쪽이라도 NO 확정 시 true → 6번 발송 생략
  skipDayEveReminder Boolean @default(false) @map("skip_day_eve_reminder")

  /// 7번 후속 확정/취소 친구톡을 이미 보냈으면 true (중복 방지)
  mondayOutcomeSent Boolean @default(false) @map("monday_outcome_sent")
  /// 7번 양쪽 응답 확정 결과: CONFIRMED | CANCELLED
  mondayOutcome String? @map("monday_outcome")
  /// 7번 후속 확정/취소 친구톡 발송 완료 시각
  mondayOutcomeSentAt DateTime? @map("monday_outcome_sent_at")
  /// (레거시) 전날 RSVP 후속 발송 여부 — 전날 버튼 제거 후 미사용
  dayEveOutcomeSent Boolean @default(false) @map("day_eve_outcome_sent")
  /// 6번(전날) 친구톡을 수동·크론으로 보낸 시각 — 중복 발송 방지
  dayEveReminderSentAt DateTime? @map("day_eve_reminder_sent_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("matching_friend_talk_rsvps")
}

/// 만남 당일 후기 친구톡 버튼 응답. 매칭·유저당 1행.
model MatchingMeetingFeedback {
  id         String   @id @default(uuid()) @db.Uuid
  matchingId String   @map("matching_id") @db.Uuid
  identityId String   @map("identity_id") @db.Uuid
  /// similar | different | neutral
  choice     String
  createdAt  DateTime @default(now()) @map("created_at")

  matching Matching @relation(fields: [matchingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([matchingId, identityId])
  @@index([matchingId])
  @@map("matching_meeting_feedbacks")
}

/// 카카오 친구톡 버튼 URL 제한을 피하기 위한 짧은 링크 저장소.
model FriendTalkRsvpLink {
  code       String   @id
  matchingId String?  @map("matching_id") @db.Uuid
  identityId String   @map("identity_id") @db.Uuid
  phase      String
  choice     String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@index([matchingId])
  @@map("friend_talk_rsvp_links")
}

/// 소개팅 매칭 단위 QR 채팅 메시지. 행은 유지되며 관리자는 항상 조회 가능.
model MeetingChatMessage {
  id         String   @id @default(uuid()) @db.Uuid
  matchingId String   @map("matching_id") @db.Uuid
  matching   Matching @relation(fields: [matchingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  senderId   String   @map("sender_id") @db.Uuid
  sender     Identity @relation("MeetingChatSender", fields: [senderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  body       String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([matchingId, createdAt])
  @@map("meeting_chat_messages")
}

/// 학교 소속 증빙 이미지 제출 1건. 이메일 인증과 별도로 관리자가 `approved` 처리하면 `Identity.schoolProofVerifiedAt`이 설정됩니다.
model SchoolProofSubmission {
  id         String   @id @default(uuid()) @db.Uuid
  identityId String   @map("identity_id") @db.Uuid
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  /// 서버 루트 기준 상대 경로(예: uploads/school-proof/<uuid>.jpg). 외부 공개 URL이 아닙니다.
  storedPath String   @map("stored_path")
  mimeType   String   @map("mime_type")
  fileSize   Int      @map("file_size")
  /// pending | approved | rejected
  status     String   @default("pending")
  reviewedAt DateTime? @map("reviewed_at")
  reviewerAdminId String? @map("reviewer_admin_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@index([identityId, status])
  @@index([status, createdAt])
  @@map("school_proof_submissions")
}

/// 공개 웹앱 행동 분석 — 의미 있는 이벤트(퍼널·화면 등). 행 단위 append-only.
model AnalyticsEvent {
  id             String    @id @default(uuid()) @db.Uuid
  sessionId      String    @map("session_id") @db.Uuid
  userUuid       String?   @map("user_uuid") @db.Uuid
  app            String
  release        String?
  clientTs       DateTime? @map("client_ts")
  name           String
  eventTs        DateTime  @map("event_ts")
  props          Json?
  /// 선택. 이후 idempotency·중복 제거용으로 클라이언트가 보낼 수 있음(현재는 저장만).
  clientEventId  String?   @map("client_event_id") @db.Uuid
  receivedAt     DateTime  @default(now()) @map("received_at")

  @@index([sessionId, receivedAt])
  @@index([app, eventTs])
  @@index([receivedAt])
  @@map("analytics_events")
}

/// 세션당 최신 하트비트·이탈(10분 무활동) 집계용 narrow 행. UPSERT.
model AnalyticsSessionHeartbeat {
  sessionId                String    @id @map("session_id") @db.Uuid
  userUuid                 String?   @map("user_uuid") @db.Uuid
  lastMeaningfulActivityAt DateTime  @map("last_meaningful_activity_at")
  visibility               String?
  context                  Json?
  clientTs                 DateTime? @map("client_ts")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  @@index([lastMeaningfulActivityAt])
  @@map("analytics_session_heartbeats")
}

/// dead click·rage tap 등 고밀도 상호작용. append-only.
model AnalyticsInteraction {
  id              String   @id @default(uuid()) @db.Uuid
  sessionId       String   @map("session_id") @db.Uuid
  userUuid        String?  @map("user_uuid") @db.Uuid
  type            String
  ts              DateTime
  xNorm           Float    @map("x_norm")
  yNorm           Float    @map("y_norm")
  nearestRegion   String   @map("nearest_region")
  view            String
  receivedAt      DateTime @default(now()) @map("received_at")

  @@index([sessionId, ts])
  @@index([type, receivedAt])
  @@map("analytics_interactions")
}

/// `x-user-uuid`가 온 요청에서 session_id ↔ Identity.id 연결(선택).
model AnalyticsSessionUserLink {
  sessionId String   @id @map("session_id") @db.Uuid
  userUuid  String   @map("user_uuid") @db.Uuid
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userUuid])
  @@map("analytics_session_user_links")
}

/// 랜딩 화면 더블탭 좋아요 합계. 행 키는 고정(`default`) 한 줄만 사용합니다.
model LandingLikeCounter {
  key       String   @id @map("key")
  likeCount Int      @default(0) @map("like_count")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("landing_like_counters")
}

/// 축제 매칭 신청 1건(KST `appliedLocalDate`·`normalizeKoMobile` 기준 전화번호당 1행; 본인확인 없음·번호 오기재는 이용자 책임).
model FestivalApplication {
  id                BigInt        @id @default(autoincrement())
  receptionId       String        @unique @map("reception_id")
  /// 1 = 첫 매칭(예: 14시), 2 = 두 번째(예: 17시) — 제출 시각·설정 시간으로 결정
  matchingSlot      Int           @default(1) @map("matching_slot")
  /// 신청이 속한 축제 "날짜"(KST 달력) — 회차별 정원 카운트에 사용
  appliedLocalDate  DateTime      @db.Date @map("applied_local_date")
  peopleCount       Int           @map("people_count")
  vibe              String
  gender            String        @db.Char(1)
  phone             String
  instagram         String?
  contactPreference String        @map("contact_preference")
  status            String        @default("APPLIED")
  createdAt         DateTime      @default(now()) @map("created_at")
  deletedAt         DateTime?     @map("deleted_at")

  @@unique([phone, appliedLocalDate], map: "festival_applications_phone_applied_local_date_key")
  @@index([gender, status], map: "festival_applications_gender_status_idx")
  @@index([gender, status, matchingSlot, appliedLocalDate], map: "festival_applications_slot_day_idx")
  @@map("festival_applications")
}

/// 축제 전역 설정. 활성 행 하나를 기준으로 매칭 시각·정원을 제공합니다.
model FestivalConfig {
  id                   Int      @id @default(autoincrement())
  matchTargetTime      DateTime @map("match_target_time")
  maxCapacityPerGender Int      @default(50) @map("max_capacity_per_gender")
  /// 첫 회차 카카오/운영 매칭 기준 시각(KST 벽시계 시·0~23)
  slot1MatchHour       Int      @default(14) @map("slot1_match_hour")
  slot2MatchHour       Int      @default(17) @map("slot2_match_hour")
  isActive             Boolean  @default(true) @map("is_active")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("festival_configs")
}
